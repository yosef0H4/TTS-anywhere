{
  "name": "tts-snipper",
  "version": "0.1.0",
  "private": true,
  "description": "Dual-mode Electron/Web TTS snipper",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "npm run build:electron:main && concurrently -k \"npm:dev:web\" \"npm:dev:electron:main\" \"npm:dev:electron:launch\"",
    "check:no-any": "eslint \"src/**/*.{ts,cts,mts}\" \"tests/**/*.ts\" \"services/nodehotkey/src/**/*.ts\" vite.config.ts vitest.config.ts playwright.config.ts playwright.core.config.ts --max-warnings=0",
    "build:electron:main": "npm run check:no-any && tsc -p tsconfig.electron.json",
    "dev:electron:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron:launch": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "npm run check:no-any && vite build",
    "build:electron": "npm run check:no-any && npm run build:web && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:chunking && npm run test:openai && npm run test:settings",
    "test:chunking": "vitest run src/tests/chunking.test.ts --pool=threads --maxWorkers=1",
    "test:openai": "vitest run src/tests/openai-client.test.ts --pool=threads --maxWorkers=1",
    "test:settings": "vitest run src/tests/settings-store.test.ts --pool=threads --maxWorkers=1",
    "test:nodehotkey": "npm --prefix services/nodehotkey run build && node scripts/nodehotkey-manual-test.mjs",
    "test:nodehotkey:electron": "npm --prefix services/nodehotkey run build && electron scripts/electron-nodehotkey-test.mjs",
    "test:watch": "vitest",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test --project=web",
    "test:e2e:electron": "npm run build:electron:main && cross-env PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test --project=electron",
    "test:e2e:all": "npm run build:electron:main && cross-env PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test --project=web --project=electron",
    "test:e2e:loop": "node scripts/e2e-loop.mjs",
    "test:e2e:loop:edge": "cross-env E2E_USE_EDGE_TTS=1 node scripts/e2e-loop.mjs",
    "test:e2e:core": "cross-env PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test -c playwright.core.config.ts --project=core-web"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "lucide": "^0.576.0",
    "nodehotkey": "file:services/nodehotkey",
    "openai": "^6.25.0",
    "tom-select": "^2.5.2"
  }
}
