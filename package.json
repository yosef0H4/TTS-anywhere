{
  "name": "tts-snipper",
  "version": "0.1.0",
  "private": true,
  "description": "Dual-mode Electron/Web TTS snipper",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "concurrently -k \"npm:dev:web\" \"npm:dev:electron:main\" \"npm:dev:electron:launch\"",
    "dev:electron:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron:launch": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "build:electron": "npm run build:web && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:chunking && npm run test:openai && npm run test:settings",
    "test:chunking": "vitest run src/tests/chunking.test.ts --pool=threads --maxWorkers=1",
    "test:openai": "vitest run src/tests/openai-client.test.ts --pool=threads --maxWorkers=1",
    "test:settings": "vitest run src/tests/settings-store.test.ts --pool=threads --maxWorkers=1",
    "test:nodehotkey": "npm --prefix services/nodehotkey run build && node scripts/nodehotkey-manual-test.mjs",
    "test:nodehotkey:electron": "npm --prefix services/nodehotkey run build && electron scripts/electron-nodehotkey-test.mjs",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "lucide": "^0.576.0",
    "nodehotkey": "file:services/nodehotkey",
    "openai": "^6.25.0",
    "tom-select": "^2.5.2"
  }
}
