{
  "schemaVersion": 1,
  "id": "supertonic",
  "name": "Supertonic TTS",
  "family": "tts",
  "description": "OpenAI-compatible Supertonic 3 multilingual TTS adapter with ONNX and NVIDIA PyTorch CUDA presets.",
  "healthPath": "/healthz",
  "launcher": {
    "executable": "uv",
    "args": ["run", "python", "launcher.py"]
  },
  "selectors": [
    {
      "id": "supertonic-cpu",
      "name": "Supertonic CPU",
      "presetId": "cpu",
      "capabilities": ["speech"]
    },
    {
      "id": "supertonic-gpu",
      "name": "Supertonic ONNX GPU",
      "presetId": "gpu",
      "capabilities": ["speech"]
    },
    {
      "id": "supertonic-nvidia",
      "name": "Supertonic NVIDIA",
      "presetId": "nvidia",
      "capabilities": ["speech"]
    }
  ],
  "presets": [
    {
      "id": "cpu",
      "name": "CPU",
      "defaultPort": 8017,
      "args": ["--runtime", "cpu"],
      "env": {
        "UV_PROJECT_ENVIRONMENT": ".venv-cpu"
      },
      "capabilities": ["speech"],
      "configTargets": ["tts.baseUrl"],
      "runtime": {
        "speech": "cpu"
      }
    },
    {
      "id": "gpu",
      "name": "GPU",
      "defaultPort": 8018,
      "args": ["--runtime", "gpu"],
      "env": {
        "UV_PROJECT_ENVIRONMENT": ".venv-gpu"
      },
      "capabilities": ["speech"],
      "configTargets": ["tts.baseUrl"],
      "runtime": {
        "speech": "gpu"
      }
    },
    {
      "id": "nvidia",
      "name": "NVIDIA PyTorch CUDA",
      "defaultPort": 8019,
      "args": ["--runtime", "nvidia"],
      "env": {
        "UV_PROJECT_ENVIRONMENT": ".venv-nvidia"
      },
      "capabilities": ["speech"],
      "configTargets": ["tts.baseUrl"],
      "runtime": {
        "speech": "gpu"
      }
    }
  ]
}
