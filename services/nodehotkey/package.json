    "build:ts": "tsc -p tsconfig.json",
    "build:native": "node-gyp rebuild"
  },
  "dependencies": {
    "koffi": "^2.10.1",
    "node-addon-api": "^8.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
